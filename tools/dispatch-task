#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$SCRIPT_DIR/_build-helper.sh"
ensure_binary "dispatch-task"

if [[ " $* " == *" --repo-root "* ]] || [[ " $* " == *" --repo-root="* ]]; then
	exec "$BINARY" "$@"
fi

exec "$BINARY" --repo-root "$REPO_ROOT" "$@"
