#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$SCRIPT_DIR/_build-helper.sh"
ensure_binary "record-dispatch"

DISPATCH_REPO_ROOT="$REPO_ROOT"
HAS_REPO_ROOT=false
EXPECT_REPO_ROOT_VALUE=false

for arg in "$@"; do
	if [ "$EXPECT_REPO_ROOT_VALUE" = true ]; then
		DISPATCH_REPO_ROOT="$arg"
		HAS_REPO_ROOT=true
		EXPECT_REPO_ROOT_VALUE=false
		continue
	fi

	case "$arg" in
		--repo-root)
			EXPECT_REPO_ROOT_VALUE=true
			;;
		--repo-root=*)
			HAS_REPO_ROOT=true
			DISPATCH_REPO_ROOT="${arg#--repo-root=}"
			;;
	esac
done

RECORD_DISPATCH_BINARY="$BINARY"

if [ "$HAS_REPO_ROOT" = true ]; then
	RECORD_DISPATCH_OUTPUT="$("$RECORD_DISPATCH_BINARY" "$@")"
else
	RECORD_DISPATCH_OUTPUT="$("$RECORD_DISPATCH_BINARY" --repo-root "$REPO_ROOT" "$@")"
fi

bash "$SCRIPT_DIR/derive-metrics" --apply --repo-root "$DISPATCH_REPO_ROOT" >/dev/null
printf '%s\n' "$RECORD_DISPATCH_OUTPUT"
