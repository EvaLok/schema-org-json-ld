#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$SCRIPT_DIR/_build-helper.sh"
ensure_binary "metric-snapshot"

# Parse flags from args (non-destructive scan)
has_repo_root=false
has_fix=false
has_refresh_unchanged=false
cycle_num=""
prev=""
for arg in "$@"; do
	case "$arg" in
		--repo-root|--repo-root=*)
			has_repo_root=true
			;;
		--fix)
			has_fix=true
			;;
		--refresh-unchanged)
			has_refresh_unchanged=true
			;;
		--cycle=*)
			cycle_num="${arg#--cycle=}"
			;;
	esac
	if [ "$prev" = "--cycle" ]; then
		cycle_num="$arg"
	fi
	prev="$arg"
done

# Run the binary
if [ "$has_repo_root" = true ]; then
	"$BINARY" "$@"
else
	"$BINARY" --repo-root "$REPO_ROOT" "$@"
fi

# After --fix, commit state.json changes and output the receipt hash
if { [ "$has_fix" = true ] || [ "$has_refresh_unchanged" = true ]; } && [ -n "$cycle_num" ]; then
	summary="auto-fix metric mismatches"
	if [ "$has_fix" != true ] && [ "$has_refresh_unchanged" = true ]; then
		summary="refresh unchanged metric freshness markers"
	fi
	RECEIPT=$(bash "$SCRIPT_DIR/commit-state-change" --tool-name "metric-snapshot" --summary "$summary" --cycle "$cycle_num" 2>&1) || true
	if echo "$RECEIPT" | grep -qE '^[0-9a-f]{7}$'; then
		echo "commit-receipt: $RECEIPT"
	elif [ -n "$RECEIPT" ]; then
		echo "commit-state-change: $RECEIPT" >&2
	fi
fi
