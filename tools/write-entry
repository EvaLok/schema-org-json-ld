#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
BINARY="$SCRIPT_DIR/rust/target/release/write-entry"

if [ ! -x "$BINARY" ]; then
	echo "Pre-built binary not found, building..." >&2
	cargo build --release --manifest-path "$SCRIPT_DIR/rust/Cargo.toml" -p write-entry >&2
fi

has_repo_root=false
for arg in "$@"; do
	case "$arg" in
		--repo-root|--repo-root=*)
			has_repo_root=true
			;;
	esac
done

if [ "$has_repo_root" = true ]; then
	exec "$BINARY" "$@"
fi

# No args or --help: pass through directly (let clap show usage)
if [ $# -eq 0 ]; then
	exec "$BINARY" --help
fi

# Insert --repo-root after the subcommand (first positional arg)
subcommand="$1"
shift
exec "$BINARY" "$subcommand" --repo-root "$REPO_ROOT" "$@"
