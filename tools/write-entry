#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
BINARY="$SCRIPT_DIR/rust/target/release/write-entry"

if [ ! -x "$BINARY" ]; then
	echo "Pre-built binary not found, building..." >&2
	cargo build --release --manifest-path "$SCRIPT_DIR/rust/Cargo.toml" -p write-entry >&2
fi

# No args: pass through help directly.
if [ $# -eq 0 ]; then
	exec "$BINARY" --help
fi

case " $* " in
	*" --repo-root "*|*" --repo-root="*)
		exec "$BINARY" "$@"
		;;
esac

exec "$BINARY" --repo-root "$REPO_ROOT" "$@"
