#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
BINARY="$SCRIPT_DIR/rust/target/release/backfill-sessions"

if [ ! -f "$BINARY" ] || [ ! -x "$BINARY" ]; then
	echo "Pre-built binary not found, building..." >&2
	cargo build --release -p backfill-sessions --manifest-path "$SCRIPT_DIR/rust/Cargo.toml" >&2
fi

for arg in "$@"; do
	case "$arg" in
		--repo-root|--repo-root=*)
			exec "$BINARY" "$@"
			;;
	esac
done

exec "$BINARY" --repo-root "$REPO_ROOT" "$@"
