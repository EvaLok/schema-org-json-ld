#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$SCRIPT_DIR/_build-helper.sh"
ensure_binary "cross-repo"

for arg in "$@"; do
	case "$arg" in
		--repo-root|--repo-root=*)
			exec "$BINARY" create-audit-inbound "$@"
			;;
	esac
done

exec "$BINARY" create-audit-inbound --repo-root "$REPO_ROOT" "$@"
